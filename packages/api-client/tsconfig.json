{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"declaration": true,
		"noEmit": true,
		"types": ["bun-types"]
	},
	"include": ["src/**/*", "orval.config.ts"]
}
