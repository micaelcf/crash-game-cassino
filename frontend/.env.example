# Logto (OIDC IdP)
# From Logto admin console → Applications → your SPA app.
# For local dev against the Podman/WSL Logto container, use 127.0.0.1 (not
# localhost) — Chrome resolves localhost to IPv6 ::1, but the WSL port relay
# only binds IPv4, so the OIDC discovery fetch silently fails and the SDK
# spins on isLoading forever.
VITE_LOGTO_ENDPOINT=https://your-tenant.logto.app/
VITE_LOGTO_APP_ID=

# API resource indicator for protected backend calls.
# Must match the indicator created by scripts/seed-logto.ts (CFG.apiResource.indicator).
# Without this, Logto returns an opaque userinfo token and the wallets/games
# JWT guard rejects it with 401.
VITE_LOGTO_RESOURCE=https://api.crash-game.local

# REST API (Kong gateway)
VITE_API_BASE_URL=http://localhost:8000

# Game WebSocket (Socket.IO on games service, proxied by Kong at /socket.io)
VITE_WS_URL=http://localhost:8000

# Backend (TanStack Start server-side only)
# SERVER_URL=http://localhost:3001
