{
	"name": "crash-game",
	"private": true,
	"workspaces": ["services/*", "packages/*", "frontend"],
	"scripts": {
		"docker:up": "podman compose up",
		"docker:down": "podman compose down",
		"docker:prune": "podman compose down -v --rmi all --remove-orphans && podman volume prune -f"
	},
	"devDependencies": {
		"bun-types": "latest"
	}
}
