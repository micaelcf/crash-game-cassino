{
	"name": "@crash/wallets",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/main.ts",
		"start": "bun run src/main.ts",
		"swagger:dump": "bun run scripts/dump-openapi.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run src",
		"test:watch": "vitest src",
		"test:integration": "vitest run tests/integration tests/e2e",
		"test:e2e": "vitest run tests/e2e",
		"test:all": "vitest run",
		"test:coverage": "vitest run --coverage",
		"mikro-orm": "bun --bun node_modules/.bin/mikro-orm",
		"migration:create": "bun --bun node_modules/.bin/mikro-orm migration:create",
		"migration:create:initial": "bun --bun node_modules/.bin/mikro-orm migration:create --initial",
		"migration:up": "bun --bun node_modules/.bin/mikro-orm migration:up",
		"migration:down": "bun --bun node_modules/.bin/mikro-orm migration:down",
		"migration:pending": "bun --bun node_modules/.bin/mikro-orm migration:pending",
		"migration:list": "bun --bun node_modules/.bin/mikro-orm migration:list",
		"migration:fresh": "bun --bun node_modules/.bin/mikro-orm migration:fresh"
	},
	"mikro-orm": {
		"useTsNode": true,
		"configPaths": ["./src/infrastructure/db/mikro-orm.config.ts"]
	},
	"dependencies": {
		"@crash/contracts": "workspace:*",
		"@fastify/static": "^8.0.0",
		"@mikro-orm/core": "^7.0.16",
		"@mikro-orm/migrations": "^7.0.16",
		"@mikro-orm/nestjs": "^7.0.1",
		"@mikro-orm/postgresql": "^7.0.16",
		"@nestjs/common": "^11.1.17",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.17",
		"@nestjs/cqrs": "^11.0.3",
		"@nestjs/microservices": "^11.1.17",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-fastify": "^11.1.17",
		"@nestjs/schedule": "^4.1.2",
		"@nestjs/swagger": "^11.0.0",
		"@scalar/nestjs-api-reference": "^1.1.16",
		"@willsoto/nestjs-prometheus": "^6.1.0",
		"amqp-connection-manager": "^4.1.14",
		"amqplib": "^0.10.5",
		"big.js": "^7.0.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.2",
		"jwks-rsa": "^3.1.0",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@mikro-orm/cli": "^7.0.16",
		"@nestjs/testing": "^11.1.21",
		"@types/amqplib": "^0.10.7",
		"@types/big.js": "^6.2.2",
		"@types/passport-jwt": "^4.0.1",
		"@types/supertest": "^6.0.2",
		"@types/uuid": "^11.0.0",
		"@vitest/coverage-v8": "^4.1.6",
		"bun-types": "latest",
		"supertest": "^7.0.0",
		"testcontainers": "^10.18.0",
		"typescript": "^5.8.3",
		"unplugin-swc": "^1.5.7",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.6"
	}
}
