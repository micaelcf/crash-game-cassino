# Force LF for shell scripts and POSIX-only files.
# Required so the Postgres init script and Dockerfiles parse correctly
# inside Linux containers when the repo is cloned on Windows.
*.sh         text eol=lf
Dockerfile   text eol=lf
*.dockerfile text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# Lockfiles and generated artifacts — leave untouched.
bun.lock     binary
