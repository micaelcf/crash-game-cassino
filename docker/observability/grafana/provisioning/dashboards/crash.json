{
	"annotations": { "list": [] },
	"editable": true,
	"graphTooltip": 0,
	"id": null,
	"title": "Crash Game",
	"tags": ["crash", "game", "casino"],
	"schemaVersion": 39,
	"time": { "from": "now-1h", "to": "now" },
	"timepicker": {},
	"timezone": "",
	"version": 1,
	"refresh": "10s",
	"panels": [
		{
			"id": 1,
			"type": "stat",
			"title": "RTP (5m rolling)",
			"gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
			"targets": [
				{
					"expr": "sum(rate(crash_payout_cents_sum[5m])) / clamp_min(sum(rate(crash_bet_amount_cents_sum[5m])), 1)",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
					"color": { "mode": "thresholds" },
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "orange", "value": 0.9 },
							{ "color": "green", "value": 0.95 }
						]
					}
				}
			}
		},
		{
			"id": 2,
			"type": "timeseries",
			"title": "Bet rate by status (bets/s)",
			"gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
			"targets": [
				{
					"expr": "sum by (status) (rate(crash_bets_total[1m]))",
					"legendFormat": "{{status}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 3,
			"type": "stat",
			"title": "Bets placed (last 24h)",
			"gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
			"targets": [
				{
					"expr": "sum(increase(crash_bets_total{status=\"placed\"}[24h]))",
					"refId": "A"
				}
			]
		},
		{
			"id": 4,
			"type": "timeseries",
			"title": "WebSocket emit latency (ms)",
			"gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
			"targets": [
				{
					"expr": "histogram_quantile(0.50, sum by (le, event) (rate(crash_ws_emit_duration_ms_bucket[5m])))",
					"legendFormat": "p50 {{event}}",
					"refId": "A"
				},
				{
					"expr": "histogram_quantile(0.95, sum by (le, event) (rate(crash_ws_emit_duration_ms_bucket[5m])))",
					"legendFormat": "p95 {{event}}",
					"refId": "B"
				},
				{
					"expr": "histogram_quantile(0.99, sum by (le, event) (rate(crash_ws_emit_duration_ms_bucket[5m])))",
					"legendFormat": "p99 {{event}}",
					"refId": "C"
				}
			]
		},
		{
			"id": 5,
			"type": "timeseries",
			"title": "Outbox publish lag p95 (ms)",
			"gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (le, service) (rate(crash_outbox_publish_lag_ms_bucket[5m])))",
					"legendFormat": "p95 {{service}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 6,
			"type": "timeseries",
			"title": "Wallet operations (ops/s)",
			"gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
			"targets": [
				{
					"expr": "sum by (op) (rate(crash_wallet_operations_total[1m]))",
					"legendFormat": "{{op}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 7,
			"type": "timeseries",
			"title": "Stake throughput (cents/s)",
			"gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
			"targets": [
				{
					"expr": "rate(crash_bet_amount_cents_sum[1m])",
					"legendFormat": "stake",
					"refId": "A"
				},
				{
					"expr": "rate(crash_payout_cents_sum[1m])",
					"legendFormat": "payout",
					"refId": "B"
				}
			]
		}
	]
}
